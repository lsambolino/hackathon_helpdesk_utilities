# Copy to .env and fill in your values

ANTHROPIC_API_KEY=sk-ant-...

# URL of the hackathon chatbot endpoint (POST /chat)
# Payload:   { "message": "...", "session_id": "..." }
# Response:  { "reply": "..." }
CHATBOT_ENDPOINT=http://localhost:8080/chat

# Optional overrides
EVALUATOR_MODEL=claude-sonnet-4-6
MAX_TURNS=8
NUM_SCENARIOS=5
OUTPUT_DIR=./results
