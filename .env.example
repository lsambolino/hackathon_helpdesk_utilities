# Helpdesk Utilities — runtime configuration
# Copy to .env and edit for your environment, OR export the variables in your shell.
#
# Pick ONE provider section.

# ─────────────────────────────────────────────────────────────────────
# A) Anthropic API (default)
# ─────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────
# B) AWS Bedrock
# ─────────────────────────────────────────────────────────────────────
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_PROFILE=octopus-base        # any profile from ~/.aws/credentials
# # Optional — pin specific cross-region inference profile IDs:
# # ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-6
# # ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ─────────────────────────────────────────────────────────────────────
# Common overrides
# ─────────────────────────────────────────────────────────────────────
# HELPDESK_MODEL=                   # overrides the per-role default
# HELPDESK_LOG_LEVEL=info
